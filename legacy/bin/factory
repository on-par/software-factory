#!/usr/bin/env bash
# bin/factory — Software Factory CLI
#
# Multi-agent software factory with boss-worker-checker orchestration,
# cost-tier model routing, and automatic failover across providers.
#
# Evolved from the single-model factory v1 to support:
#   - Independent checker agents (structural anti-hallucination)
#   - Multi-provider model routing with automatic failover
#   - Per-product constitutions (written standards enforced on every task)
#   - Worker ↔ checker ↔ boss dispute resolution
#
# Usage:
#   factory init                        Initialize .factory in this repo
#   factory constitution --list          List available product constitutions
#   factory constitution --product <p>   Set the active constitution for this repo
#   factory triage                       Propose a queue from open issues
#   factory run                          Process the whole queue (lanes in parallel)
#   factory run-lane <lane>              Process one lane serially
#   factory ship <N>                     Plan → build → check → ship one issue
#   factory check <N>                    Run checkers on an issue's worktree
#   factory land <N>                     Squash-merge a ready PR
#   factory status                       Show queue, events, PRs, models
#   factory stop | resume                Halt / resume between issues
#   factory models                       List available models and costs
#   factory cost                         Show cost tracking summary
#
# Env knobs:
#   FACTORY_PRODUCT          Active product constitution (overrides .factory/product)
#   FACTORY_BYOK=1           Only use models whose API keys are present
#   FACTORY_MERGE=1          Authorize autonomous squash-merge
#   FACTORY_CODEX=0          Disable Codex routing (force all-Claude)
#   FACTORY_PLAN_TIMEOUT     Plan phase timeout (default 1800s)
#   FACTORY_BUILD_TIMEOUT    Build phase timeout (default 7200s)
#   FACTORY_CHECK_TIMEOUT    Check phase timeout (default 1800s)

set -euo pipefail

# Resolve factory root (where this script's sibling lib/ and config/ live)
FACTORY_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Source all lib modules
for lib in "$FACTORY_ROOT"/lib/*.sh; do
  [ -f "$lib" ] && . "$lib"
done
for phase in "$FACTORY_ROOT"/lib/phases/*.sh; do
  [ -f "$phase" ] && . "$phase"
done

# Resolve repo context
REPO="$(git rev-parse --show-toplevel 2>/dev/null)" \
  || { echo "factory: not inside a git repository" >&2; exit 2; }
GH_REPO="$(gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null)" \
  || { echo "factory: no GitHub remote detected" >&2; exit 2; }

STATE="$REPO/.factory"
QUEUE="$STATE/queue"
EVENTS="$STATE/events.ndjson"
LOGS="$STATE/logs"
PLANS="$STATE/plans"
STOP_FILE="$STATE/STOP"
PRODUCT_FILE="$STATE/product"

mkdir -p "$STATE" "$LOGS" "$PLANS"
grep -qx '.factory/' "$REPO/.git/info/exclude" 2>/dev/null \
  || echo '.factory/' >> "$REPO/.git/info/exclude"

# Logging
log_event() {
  printf '{"ts":"%s","type":"%s","issue":"%s","msg":%s}\n' \
    "$(date -u +%FT%TZ)" "$1" "$2" \
    "$(jq -Rn --arg m "$3" '$m')" >> "$EVENTS" 2>/dev/null || true
  echo "[factory] $1 #$2: $3"
}

# Active product constitution
get_product() { cat "$PRODUCT_FILE" 2>/dev/null || echo "${FACTORY_PRODUCT:-}"; }
set_product() { echo "$1" > "$PRODUCT_FILE"; echo "active product: $1"; }

# ---------- commands ----------

cmd_init() {
  [ -e "$QUEUE" ] || cat > "$QUEUE" <<'EOF'
# factory queue — "<lane> <issue#>", priority-ordered.
# Lanes run in parallel; issues within a lane run serially.
# Put issues that touch the same files in the same lane.
# Example:
#   app 61
#   docs 66
EOF
  echo "initialized $STATE"
  echo "next: factory constitution --product <name>, then factory triage"
}

cmd_constitution() {
  case "${1:-}" in
    --list) constitution_products | while IFS= read -r p; do echo "  $p"; done ;;
    --product)
      shift
      local p="${1:-}"
      [ -z "$p" ] && { echo "usage: factory constitution --product <name>" >&2; exit 2; }
      constitution_load "$p" >/dev/null 2>&1 || { echo "no constitution '$p' found" >&2; exit 1; }
      set_product "$p"
      ;;
    *) echo "usage: factory constitution --list | --product <name>" >&2; exit 2 ;;
  esac
}

cmd_models() {
  echo "== Available Models =="
  models_list | while IFS= read -r m; do
    local tier cost avail
    tier="$(models_tier "$m" | tr '\n' '/')"
    cost="$(models_cost "$m" 1000000 1000000)"
    if models_available "$m"; then avail="✅"; else avail="❌"; fi
    printf "  %s %s tier=%s cost=$%s/M\n" "$avail" "$m" "${tier%/}" "$cost"
  done
  echo
  echo "== Tiers =="
  for tier in boss worker checker triage; do
    echo -n "  $tier: "
    models_in_tier "$tier" | tr '\n' ' '
    echo
  done
}

cmd_cost() {
  local cost_file="$STATE/costs.jsonl"
  [ ! -f "$cost_file" ] && { echo "no cost data yet"; return 0; }
  echo "== Cost Summary =="
  local total=0
  jq -s '.' "$cost_file" 2>/dev/null | jq -r '
    group_by(.model) | map({
      model: .[0].model,
      tasks: length,
      total_cost: (map(.cost | tonumber) | add)
    }) | .[] | "  \(.model): \(.tasks) tasks, $\(.total_cost | tostring)"
  ' 2>/dev/null
  total="$(jq -s '[.[] | .cost | tonumber] | add' "$cost_file" 2>/dev/null || echo 0)"
  echo "  ---"
  echo "  Total: \$${total}"
}

cmd_ship() {
  local n="$1" br wt
  br="${BRANCH_PREFIX:-ship-it/}$n-$(slugify "$(gh issue view "$n" --repo "$GH_REPO" --json title --jq .title)")"
  wt="$(dirname "$REPO")/$(basename "$REPO")-factory-$n"
  local product; product="$(get_product)"
  local spec="$PLANS/issue-$n.md"

  # PLAN
  log_event "plan" "$n" "starting plan phase"
  phase_plan "$n" "$wt" "$spec" "$product" || {
    local rc=$?
    [ "$rc" -eq 10 ] && { log_event "escalate" "$n" "plan escalated"; return 10; }
    log_event "fail" "$n" "plan phase failed"; return 1;
  }

  # Setup worktree
  setup_worktree "$br" "$wt" || { log_event "fail" "$n" "worktree setup failed"; return 14; }

  # BUILD
  log_event "build" "$n" "starting build phase"
  phase_build "$n" "$wt" "$spec" "$br" "$product" || {
    local rc=$?
    [ "$rc" -eq 10 ] && { log_event "escalate" "$n" "build escalated"; return 10; }
    log_event "fail" "$n" "build phase failed"; return 12;
  }

  # CHECK
  log_event "check" "$n" "running checkers"
  local check_result; check_result="$(phase_check "$n" "$wt" "$spec" "$product" 2>&1)"
  local check_rc=$?
  local failures; failures="$(echo "$check_result" | jq -r '.failures // 0' 2>/dev/null || echo 0)"

  if [ "$failures" -gt 0 ] && [ "${FACTORY_AUTO_REWORK:-1}" = "1" ]; then
    log_event "rework" "$n" "$failures check failures — sending back to worker"
    # Rework loop (max 3 rounds)
    local round=0
    while [ "$round" -lt 3 ] && [ "$failures" -gt 0 ]; do
      round=$((round+1))
      phase_check_rework "$n" "$wt" "$spec" "$check_result" "$product"
      check_result="$(phase_check "$n" "$wt" "$spec" "$product" 2>&1)"
      check_rc=$?
      failures="$(echo "$check_result" | jq -r '.failures // 0' 2>/dev/null || echo 0)"
      log_event "check" "$n" "rework round $round: $failures failures remaining"
    done
  fi

  if [ "$failures" -gt 0 ]; then
    log_event "fail" "$n" "$failures check failures after rework — parking"
    echo "$check_result" | jq '.results[] | select(.result == "FAIL")' >&2
    return 1
  fi

  log_event "check" "$n" "all checkers passed"

  # SHIP
  log_event "ship" "$n" "creating PR"
  phase_ship "$n" "$wt" "$br" || { log_event "fail" "$n" "ship phase failed"; return 13; }

  log_event "ready" "$n" "PR ready for review"
}

setup_worktree() {
  local br="$1" wt="$2"
  git -C "$REPO" fetch origin -q
  git -C "$REPO" worktree remove --force "$wt" 2>/dev/null || true
  git -C "$REPO" branch -D "$br" 2>/dev/null || true
  git -C "$REPO" worktree add -b "$br" "$wt" origin/main >/dev/null
}

slugify() { echo "$1" | tr '[:upper:]' '[:lower:]' \
  | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' | cut -c1-32 | sed -E 's/-+$//'; }

cmd_run_lane() {
  local lane="$1"
  grep -Ev '^\s*(#|$)' "$QUEUE" | awk -v l="$lane" '$1==l {print $2}' | while IFS= read -r n; do
    [ -z "$n" ] && continue
    [ -e "$STOP_FILE" ] && { log_event "stopped" "$n" "STOP file"; return 0; }
    local rc=0; cmd_ship "$n" || rc=$?
    case "$rc" in
      0) wait_landed "$n" || { log_event "parked" "$n" "merge-wait"; return 0; } ;;
      *) log_event "parked" "$n" "failure rc=$rc"; return 0 ;;
    esac
  done
  log_event "lane-done" "$lane" "complete"
}

cmd_run() {
  [ -s "$QUEUE" ] || { echo "queue empty — run 'factory init'" >&2; exit 2; }
  rm -f "$STOP_FILE"
  local pids=()
  grep -Ev '^\s*(#|$)' "$QUEUE" | awk '{print $1}' | awk '!seen[$0]++' | while IFS= read -r lane; do
    "$0" run-lane "$lane" &
    echo "[factory] lane '$lane' started (pid $!)"
  done
  wait
  log_event "run-done" "all" "all lanes finished"
}

wait_landed() {
  local n="$1" br
  br="${BRANCH_PREFIX:-ship-it/}$n-$(slugify "$(gh issue view "$n" --repo "$GH_REPO" --json title --jq .title)")"
  while :; do
    [ -e "$STOP_FILE" ] && return 20
    local st
    st="$(gh pr list --repo "$GH_REPO" --state merged --head "$br" --json number --jq '.[0].number' 2>/dev/null || true)"
    [ -n "$st" ] && { log_event "landed" "$n" "merged"; return 0; }
    if [ "${FACTORY_MERGE:-0}" = "1" ]; then
      cmd_land "$n" && return 0 || return 21
    fi
    echo "[factory] #$n awaiting human merge (poll 120s)"
    sleep 120
  done
}

cmd_land() {
  local n="$1" br wt pr
  br="${BRANCH_PREFIX:-ship-it/}$n-$(slugify "$(gh issue view "$n" --repo "$GH_REPO" --json title --jq .title)")"
  wt="$(dirname "$REPO")/$(basename "$REPO")-factory-$n"
  git -C "$REPO" fetch origin -q || true
  pr="$(gh pr list --repo "$GH_REPO" --state open --head "$br" --json number --jq '.[0].number' 2>/dev/null || true)"
  [ -z "$pr" ] && { log_event "fail" "$n" "no PR for $br"; return 4; }
  gh pr merge "$pr" --squash --delete-branch --repo "$GH_REPO" \
    || { log_event "fail" "$n" "merge failed"; return 5; }
  log_event "merged" "$n" "squash-merged PR #$pr"
  git -C "$REPO" worktree remove --force "$wt" 2>/dev/null || true
}

cmd_status() {
  echo "== $GH_REPO =="
  echo "product: $(get_product || echo '(none)')"
  echo "plan model: $(router_resolve plan 2>/dev/null || echo 'none')"
  echo "build model: $(router_resolve build_claude 2>/dev/null || echo 'none')"
  echo "checker model: $(router_resolve check_tests 2>/dev/null || echo 'none')"
  echo
  echo "== queue =="
  [ -s "$QUEUE" ] && grep -Ev '^\s*(#|$)' "$QUEUE" || echo "(empty)"
  echo
  echo "== last events =="
  tail -12 "$EVENTS" 2>/dev/null || echo "(none)"
  echo
  echo "== open PRs =="
  gh pr list --repo "$GH_REPO" --state open --json number,title,mergeStateStatus,isDraft \
    --jq '.[] | [.number, (if .isDraft then "draft" else "ready" end), .mergeStateStatus, .title] | @tsv' 2>/dev/null || true
  echo
  echo "== worktrees =="
  git -C "$REPO" worktree list
  [ -e "$STOP_FILE" ] && echo "!! STOP file present"
}

cmd_triage() {
  local product; product="$(get_product)"
  local constitution_note=""
  [ -n "$product" ] && constitution_note="Active constitution: $product. Ensure the queue respects the constitution's scope."

  local model; model="$(router_resolve triage 2>/dev/null || echo "claude-sonnet-5")"
  local flag; flag="$(models_claude_flag "$model" 2>/dev/null || echo "--model $model")"

  echo "triaging $GH_REPO with $model..."
  claude -p "Triage the open GitHub issues of $GH_REPO for an autonomous software factory.
$constitution_note
Run: gh issue list --repo $GH_REPO --state open --limit 100 --json number,title,labels,body
Read every body. Exclude epics/PRDs/meta, external-account/credential/outreach issues,
and anything too vague. Group by lane (same-file issues together). Order by dependency then value.
Write ONLY the queue to $STATE/queue.proposed in format '<lane> <issue#>', with '#' comments
explaining exclusions." $flag --allowedTools "Bash(gh issue:*) Bash(gh repo:*) Read Glob Grep Write" \
    >/dev/null 2>&1 || true

  if [ -s "$STATE/queue.proposed" ]; then
    cat "$STATE/queue.proposed"
    echo "---"
    echo "review and: mv $STATE/queue.proposed $QUEUE"
  else
    echo "triage produced no proposal" >&2; return 1
  fi
}

case "${1:-}" in
  init)         cmd_init ;;
  constitution) shift; cmd_constitution "$@" ;;
  models)      cmd_models ;;
  cost)        cmd_cost ;;
  triage)      cmd_triage ;;
  run)         cmd_run ;;
  run-lane)    cmd_run_lane "$2" ;;
  ship)        cmd_ship "$2" ;;
  land)        cmd_land "$2" ;;
  status)      cmd_status ;;
  stop)        touch "$STOP_FILE"; echo "STOP set" ;;
  resume)      rm -f "$STOP_FILE"; echo "STOP cleared" ;;
  *)           head -40 "$0"; exit 2 ;;
esac