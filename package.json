{
  "name": "@on-par/software-factory",
  "version": "2.0.0",
  "private": true,
  "description": "Multi-agent software factory monorepo — boss-worker-checker orchestration with multi-provider model routing and per-product constitutions.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace @on-par/factory-dashboard",
    "dev": "npm run dev --workspace @on-par/factory-cli",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -b && npm run typecheck --workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "coverage-ratchet": "tsx scripts/coverage-ratchet.ts",
    "eval": "tsx scripts/eval.ts",
    "local-small-scoreboard": "tsx scripts/local-small-scoreboard.ts",
    "eval-history": "tsx scripts/eval-history.ts",
    "regression-issue": "tsx scripts/regression-issue.ts",
    "knip": "knip",
    "clean": "rm -rf packages/*/dist packages/*/node_modules"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.39.0",
    "jsdom": "^29.1.1",
    "knip": "^6.29.0",
    "prettier": "3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "ts-api-utils": {
      "typescript": "^5.9.0"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/on-par/software-factory.git"
  },
  "homepage": "https://github.com/on-par/software-factory#readme",
  "bugs": {
    "url": "https://github.com/on-par/software-factory/issues"
  }
}
