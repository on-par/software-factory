{
  "name": "@on-par/software-factory",
  "version": "2.0.0",
  "private": true,
  "description": "Multi-agent software factory monorepo — boss-worker-checker orchestration with multi-provider model routing and per-product constitutions.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "npm run dev --workspace @on-par/factory-cli",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "tsc -b && npm run typecheck --workspaces",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "eval": "tsx scripts/eval.ts",
    "regression-issue": "tsx scripts/regression-issue.ts",
    "clean": "rm -rf packages/*/dist packages/*/node_modules"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.0",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^3.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/on-par/software-factory.git"
  },
  "homepage": "https://github.com/on-par/software-factory#readme",
  "bugs": {
    "url": "https://github.com/on-par/software-factory/issues"
  }
}
