{
  "name": "@on-par/factory-config",
  "version": "2.0.0",
  "description": "Shared configuration files and product constitutions for the Software Factory.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./models.json": "./src/models.json",
    "./routes.json": "./src/routes.json",
    "./factory.json": "./src/factory.json",
    "./constitutions/*": "./src/constitutions/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/on-par/software-factory.git",
    "directory": "packages/config"
  },
  "homepage": "https://github.com/on-par/software-factory#readme",
  "bugs": {
    "url": "https://github.com/on-par/software-factory/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0"
  }
}
