{
  "version": 1,
  "description": "Model registry for the Software Factory. Defines providers, costs, capabilities, and failover chains.",
  "models": {
    "claude-fable-5": {
      "provider": "anthropic",
      "tier": "boss",
      "costPerMtokInput": 8.0,
      "costPerMtokOutput": 40.0,
      "contextWindow": 200000,
      "capabilities": [
        "planning",
        "design",
        "architecture",
        "review",
        "dispute_resolution"
      ],
      "envKey": null,
      "claudeFlag": "fable",
      "note": "Claude Fable 5 — most capable model, uses claude CLI subscription auth. Falls back to opus on rate-limit/usage-cap."
    },
    "claude-opus-4-8": {
      "provider": "anthropic",
      "tier": "boss",
      "costPerMtokInput": 5.0,
      "costPerMtokOutput": 25.0,
      "contextWindow": 200000,
      "capabilities": [
        "planning",
        "design",
        "architecture",
        "review",
        "dispute_resolution"
      ],
      "envKey": null,
      "claudeFlag": "claude-opus-4-8",
      "note": "Uses claude CLI subscription auth, no API key needed."
    },
    "claude-sonnet-5": {
      "provider": "anthropic",
      "tier": [
        "checker",
        "boss_fallback",
        "worker_fallback"
      ],
      "costPerMtokInput": 3.0,
      "costPerMtokOutput": 15.0,
      "contextWindow": 200000,
      "capabilities": [
        "review",
        "verification",
        "implementation",
        "triage"
      ],
      "envKey": null,
      "claudeFlag": "claude-sonnet-5",
      "note": "Uses claude CLI subscription auth, no API key needed."
    },
    "gpt-5.6-sol": {
      "provider": "openai",
      "tier": [
        "worker"
      ],
      "costPerMtokInput": 1.25,
      "costPerMtokOutput": 10.0,
      "contextWindow": 272000,
      "capabilities": [
        "implementation",
        "codex"
      ],
      "envKey": null,
      "codex": true,
      "codexFlag": "-m gpt-5.6-sol -c model_reasoning_effort=medium",
      "note": "Codex CLI subscription auth (ChatGPT/OAuth), not an API key — do not gate availability on OPENAI_API_KEY. Explicitly pins -m gpt-5.6-sol instead of silently riding ~/.codex/config.toml's default model."
    },
    "gpt-5.1-codex": {
      "provider": "openai",
      "tier": [
        "worker"
      ],
      "costPerMtokInput": 1.25,
      "costPerMtokOutput": 10.0,
      "contextWindow": 272000,
      "capabilities": [
        "implementation",
        "codex"
      ],
      "envKey": null,
      "codex": true,
      "codexFlag": "-c model_reasoning_effort=high",
      "note": "Codex CLI subscription auth (ChatGPT/OAuth), not an API key — do not gate availability on OPENAI_API_KEY. Actual served model follows ~/.codex/config.toml's default (currently resolves to gpt-5-codex). Kept as fallback behind gpt-5.6-sol."
    },
    "gpt-4.1-mini": {
      "provider": "openai",
      "tier": "checker",
      "costPerMtokInput": 0.4,
      "costPerMtokOutput": 1.6,
      "contextWindow": 128000,
      "capabilities": [
        "verification",
        "lightweight_review"
      ],
      "envKey": "OPENAI_API_KEY",
      "claudeFlag": "gpt-4.1-mini",
      "experimental": true,
      "note": "claude-CLI wiring is unproven \u2014 the Claude CLI only serves Anthropic models"
    },
    "glm-5.2": {
      "provider": "ollama",
      "tier": "worker",
      "costPerMtokInput": 0.1,
      "costPerMtokOutput": 0.5,
      "contextWindow": 131072,
      "capabilities": [
        "implementation",
        "coding"
      ],
      "envKey": null,
      "claudeFlag": "ollama/glm-5.2:cloud",
      "experimental": true,
      "note": "speculative \u2014 opt in with FACTORY_EXPERIMENTAL=1"
    },
    "qwen2.5-coder:14b": {
      "provider": "ollama",
      "tier": [
        "boss",
        "worker",
        "checker",
        "triage"
      ],
      "costPerMtokInput": 0,
      "costPerMtokOutput": 0,
      "contextWindow": 32768,
      "capabilities": [
        "planning",
        "implementation",
        "coding",
        "review",
        "verification",
        "triage"
      ],
      "envKey": null,
      "providerModel": "qwen2.5-coder:14b",
      "providerOptions": {
        "num_ctx": 16384,
        "temperature": 0.1
      },
      "note": "Local-only Ollama coding model for 16GB Macs. Slow is acceptable; keep concurrency low."
    },
    "codex-ollama-qwen3.5:9b": {
      "provider": "ollama",
      "tier": [
        "worker"
      ],
      "costPerMtokInput": 0,
      "costPerMtokOutput": 0,
      "contextWindow": 32768,
      "capabilities": [
        "implementation",
        "coding",
        "codex"
      ],
      "envKey": null,
      "providerModel": "qwen3.5:9b",
      "providerOptions": {
        "num_ctx": 8192,
        "temperature": 0.1
      },
      "codex": true,
      "codexFlag": "--oss --local-provider ollama -m qwen3.5:9b",
      "note": "Local-only command-loop worker using Ollama qwen3.5:9b; use for build_codex so the model can edit files and run commands."
    },
    "qwen3.5:9b": {
      "provider": "ollama",
      "tier": [
        "worker",
        "checker"
      ],
      "costPerMtokInput": 0,
      "costPerMtokOutput": 0,
      "contextWindow": 65536,
      "capabilities": [
        "implementation",
        "coding",
        "review",
        "verification"
      ],
      "envKey": null,
      "providerModel": "qwen3.5:9b",
      "providerOptions": {
        "num_ctx": 8192,
        "temperature": 0.1
      },
      "note": "Local Ollama fallback/second-opinion model; supports tools/thinking in Ollama."
    },
    "qwen3:8b": {
      "provider": "ollama",
      "tier": [
        "worker",
        "checker"
      ],
      "costPerMtokInput": 0,
      "costPerMtokOutput": 0,
      "contextWindow": 40960,
      "capabilities": [
        "implementation",
        "coding",
        "review",
        "verification"
      ],
      "envKey": null,
      "providerModel": "qwen3:8b",
      "providerOptions": {
        "num_ctx": 24576,
        "temperature": 0.2
      },
      "note": "Smaller local Ollama fallback for memory-constrained runs."
    },
    "gemma4:12b": {
      "provider": "ollama",
      "tier": [
        "boss",
        "checker"
      ],
      "costPerMtokInput": 0,
      "costPerMtokOutput": 0,
      "contextWindow": 131072,
      "capabilities": [
        "planning",
        "review",
        "verification",
        "dispute_resolution"
      ],
      "envKey": null,
      "providerModel": "gemma4:12b",
      "providerOptions": {
        "num_ctx": 32768,
        "temperature": 0.2
      },
      "note": "Local Ollama planning/review alternative; expect model swaps on 16GB hosts."
    },
    "deepseek-v3": {
      "provider": "deepseek",
      "tier": "worker",
      "costPerMtokInput": 0.07,
      "costPerMtokOutput": 0.28,
      "contextWindow": 128000,
      "capabilities": [
        "implementation",
        "coding"
      ],
      "envKey": "DEEPSEEK_API_KEY",
      "claudeFlag": "deepseek/deepseek-chat",
      "experimental": true,
      "note": "speculative \u2014 opt in with FACTORY_EXPERIMENTAL=1"
    },
    "qwen-3.5-coder": {
      "provider": "ollama",
      "tier": "worker",
      "costPerMtokInput": 0.05,
      "costPerMtokOutput": 0.2,
      "contextWindow": 131072,
      "capabilities": [
        "implementation",
        "coding"
      ],
      "envKey": null,
      "claudeFlag": "ollama/qwen3.5-coder:cloud",
      "experimental": true,
      "note": "speculative \u2014 opt in with FACTORY_EXPERIMENTAL=1"
    }
  },
  "tiers": {
    "boss": [
      "qwen2.5-coder:14b",
      "gemma4:12b",
      "claude-fable-5",
      "claude-opus-4-8",
      "claude-sonnet-5",
      "glm-5.2"
    ],
    "worker": [
      "codex-ollama-qwen3.5:9b",
      "qwen2.5-coder:14b",
      "qwen3.5:9b",
      "qwen3:8b",
      "gpt-5.6-sol",
      "gpt-5.1-codex",
      "claude-sonnet-5",
      "glm-5.2",
      "deepseek-v3",
      "qwen-3.5-coder"
    ],
    "checker": [
      "qwen3.5:9b",
      "gemma4:12b",
      "qwen2.5-coder:14b",
      "qwen3:8b",
      "claude-sonnet-5",
      "gpt-4.1-mini",
      "glm-5.2"
    ],
    "triage": [
      "qwen2.5-coder:14b",
      "claude-sonnet-5",
      "glm-5.2"
    ]
  },
  "failover": {
    "triggers": [
      "rate_limit",
      "usage_cap",
      "timeout",
      "error",
      "empty_response"
    ],
    "maxRetries": 2,
    "cooldownMs": 5000,
    "escalateAfterTierExhausted": true
  },
  "routingRules": {
    "codex_available": {
      "if": "command -v codex && FACTORY_CODEX != 0",
      "worker_preferred": [
        "gpt-5.6-sol",
        "gpt-5.1-codex"
      ],
      "note": "Codex flat-rate is cheapest for implementation when available. gpt-5.6-sol pinned explicitly via -m; gpt-5.1-codex kept as fallback (rides config.toml default)."
    },
    "ollama_available": {
      "if": "command -v ollama",
      "worker_preferred_add": [
        "codex-ollama-qwen3.5:9b",
        "qwen2.5-coder:14b",
        "qwen3.5:9b",
        "qwen3:8b"
      ],
      "note": "Local Ollama models are free but slower; good for bulk work"
    },
    "byok_active": {
      "if": "FACTORY_BYOK=1",
      "skip_models_without_env": true,
      "note": "In BYOK mode, only use models whose env keys are present"
    }
  }
}
