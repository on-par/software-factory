{
  "version": 1,
  "description": "Model registry for the Software Factory. Defines providers, costs, capabilities, and failover chains.",
  "models": {
    "claude-opus-4-8": {
      "provider": "anthropic",
      "tier": "boss",
      "costPerMtokInput": 5.0,
      "costPerMtokOutput": 25.0,
      "contextWindow": 200000,
      "capabilities": [
        "planning",
        "design",
        "architecture",
        "review",
        "dispute_resolution"
      ],
      "envKey": null,
      "claudeFlag": "claude-opus-4-8",
      "note": "Uses claude CLI subscription auth, no API key needed."
    },
    "claude-sonnet-5": {
      "provider": "anthropic",
      "tier": [
        "checker",
        "boss_fallback",
        "worker_fallback"
      ],
      "costPerMtokInput": 3.0,
      "costPerMtokOutput": 15.0,
      "contextWindow": 200000,
      "capabilities": [
        "review",
        "verification",
        "implementation",
        "triage"
      ],
      "envKey": null,
      "claudeFlag": "claude-sonnet-5",
      "note": "Uses claude CLI subscription auth, no API key needed."
    },
    "gpt-5.1-codex": {
      "provider": "openai",
      "tier": [
        "worker"
      ],
      "costPerMtokInput": 1.25,
      "costPerMtokOutput": 10.0,
      "contextWindow": 272000,
      "capabilities": [
        "implementation",
        "codex"
      ],
      "envKey": "OPENAI_API_KEY",
      "codex": true,
      "codexFlag": "-c model_reasoning_effort=high"
    },
    "gpt-4.1-mini": {
      "provider": "openai",
      "tier": "checker",
      "costPerMtokInput": 0.4,
      "costPerMtokOutput": 1.6,
      "contextWindow": 128000,
      "capabilities": [
        "verification",
        "lightweight_review"
      ],
      "envKey": "OPENAI_API_KEY",
      "claudeFlag": "gpt-4.1-mini",
      "experimental": true,
      "note": "claude-CLI wiring is unproven \u2014 the Claude CLI only serves Anthropic models"
    },
    "glm-5.2": {
      "provider": "ollama",
      "tier": "worker",
      "costPerMtokInput": 0.1,
      "costPerMtokOutput": 0.5,
      "contextWindow": 131072,
      "capabilities": [
        "implementation",
        "coding"
      ],
      "envKey": null,
      "claudeFlag": "ollama/glm-5.2:cloud",
      "experimental": true,
      "note": "speculative \u2014 opt in with FACTORY_EXPERIMENTAL=1"
    },
    "deepseek-v3": {
      "provider": "deepseek",
      "tier": "worker",
      "costPerMtokInput": 0.07,
      "costPerMtokOutput": 0.28,
      "contextWindow": 128000,
      "capabilities": [
        "implementation",
        "coding"
      ],
      "envKey": "DEEPSEEK_API_KEY",
      "claudeFlag": "deepseek/deepseek-chat",
      "experimental": true,
      "note": "speculative \u2014 opt in with FACTORY_EXPERIMENTAL=1"
    },
    "qwen-3.5-coder": {
      "provider": "ollama",
      "tier": "worker",
      "costPerMtokInput": 0.05,
      "costPerMtokOutput": 0.2,
      "contextWindow": 131072,
      "capabilities": [
        "implementation",
        "coding"
      ],
      "envKey": null,
      "claudeFlag": "ollama/qwen3.5-coder:cloud",
      "experimental": true,
      "note": "speculative \u2014 opt in with FACTORY_EXPERIMENTAL=1"
    }
  },
  "tiers": {
    "boss": [
      "claude-opus-4-8",
      "claude-sonnet-5",
      "glm-5.2"
    ],
    "worker": [
      "gpt-5.1-codex",
      "claude-sonnet-5",
      "glm-5.2",
      "deepseek-v3",
      "qwen-3.5-coder"
    ],
    "checker": [
      "claude-sonnet-5",
      "gpt-4.1-mini",
      "glm-5.2"
    ],
    "triage": [
      "claude-sonnet-5",
      "glm-5.2"
    ]
  },
  "failover": {
    "triggers": [
      "rate_limit",
      "usage_cap",
      "timeout",
      "error",
      "empty_response"
    ],
    "maxRetries": 2,
    "cooldownMs": 5000,
    "escalateAfterTierExhausted": true
  },
  "routingRules": {
    "codex_available": {
      "if": "command -v codex && FACTORY_CODEX != 0",
      "worker_preferred": [
        "gpt-5.1-codex"
      ],
      "note": "Codex flat-rate is cheapest for implementation when available"
    },
    "ollama_available": {
      "if": "command -v ollama",
      "worker_preferred_add": [
        "glm-5.2",
        "qwen-3.5-coder"
      ],
      "note": "Local Ollama models are free but slower; good for bulk work"
    },
    "byok_active": {
      "if": "FACTORY_BYOK=1",
      "skip_models_without_env": true,
      "note": "In BYOK mode, only use models whose env keys are present"
    }
  }
}
