{
  "name": "@on-par/factory-core",
  "version": "2.0.0",
  "description": "Core engine: model router, constitutions, checkers, and pipeline phases for the Software Factory.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./internal": {
      "development": "./src/internal.ts",
      "import": "./dist/internal.js",
      "types": "./dist/internal.d.ts"
    },
    "./testing": {
      "development": "./src/testing.ts",
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/on-par/software-factory.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/on-par/software-factory#readme",
  "bugs": {
    "url": "https://github.com/on-par/software-factory/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@on-par/factory-config": "^2.0.0",
    "@octokit/rest": "^22.0.0",
    "execa": "^9.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0"
  }
}
