{
  "name": "@on-par/factory-cli",
  "version": "2.0.0",
  "description": "CLI for the Software Factory — ships verified GitHub issues via boss-worker-checker orchestration.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "factory": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/on-par/software-factory.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/on-par/software-factory#readme",
  "bugs": {
    "url": "https://github.com/on-par/software-factory/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@on-par/factory-core": "^2.0.0",
    "@on-par/factory-config": "^2.0.0",
    "@on-par/factory-tui": "^2.0.0",
    "@octokit/rest": "^22.0.0",
    "chalk": "^5.4.0",
    "commander": "^14.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0"
  }
}
